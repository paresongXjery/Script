local function teleportToPlayer(name)
	for _,plr in pairs(Players:GetPlayers()) do
		if plr ~= player and string.lower(plr.Name):find(string.lower(name)) then
			if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
				local myChar = player.Character
				if myChar and myChar:FindFirstChild("HumanoidRootPart") then
					
					myChar.HumanoidRootPart.CFrame =
						plr.Character.HumanoidRootPart.CFrame + Vector3.new(0,3,0)

					-- chat bubble di kepala (biar keliatan premium)
					if myChar:FindFirstChild("Head") then
						local bill = Instance.new("BillboardGui", myChar.Head)
						bill.Size = UDim2.new(0,200,0,50)
						bill.StudsOffset = Vector3.new(0,3,0)
						bill.AlwaysOnTop = true

						local txt = Instance.new("TextLabel", bill)
