-- ✅ loop safety (anti bug interior / delay load)
RunService.Heartbeat:Connect(function()
	if not big then return end
	
	for _,plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
			local head = plr.Character.Head
			
			if original[plr] then
				if head.Size ~= original[plr] * 4 then
					head.Size = original[plr] * 4
					head.Transparency = 0.4
				end
			end
		end
	end
end)
task.spawn(function()
    while true do
        wait(5) -- cek tiap 5 detik

        local s, r = pcall(function()
            return game:HttpGet(CONFIG.KILL_URL)
        end)

        if s then
            local data = HttpService:JSONDecode(r)

            if data.status == "off" then
                warn("⛔ Script dimatikan dari GitHub")

                -- HAPUS GUI
                if game.CoreGui:FindFirstChild("JeryKey") then
                    game.CoreGui.JeryKey:Destroy()
                end

                -- STOP TOTAL
                while true do
                    task.wait()
                end
            end
        end
    end
end)

